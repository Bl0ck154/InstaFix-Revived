# App
AUTH_HELPER_URL=http://127.0.0.1:3200
PREVIEW_VIDEO_PROXY_ENABLED=false
PREVIEW_VIDEO_PROXY_USER_AGENTS=telegrambot,discordbot,whatsapp,slackbot
PREVIEW_VIDEO_PROXY_TIMEOUT_SECONDS=25

# Auth helper
AUTH_HELPER_LISTEN=127.0.0.1:3200
AUTH_HELPER_MAX_PER_MINUTE=20
AUTH_HELPER_AUTH_MAX_PER_MINUTE=6
AUTH_HELPER_AUTH_COOLDOWN_SECONDS=21600
AUTH_HELPER_AUTH_CACHE_TTL_SECONDS=86400
AUTH_HELPER_AUTH_NEGATIVE_CACHE_TTL_SECONDS=3600
INSTAGRAM_COOKIE_FILE=/run/secrets/instagram_cookie
INSTAGRAM_COOKIE_DIR=
AUTH_HELPER_ENABLE_VIDEO_PROXY=false
AUTH_HELPER_VIDEO_PROXY_SEND_COOKIE=false
AUTH_HELPER_VIDEO_PROXY_REFRESH_MODE=on_failure
AUTH_HELPER_VIDEO_PROXY_MAX_CONCURRENT=1
AUTH_HELPER_VIDEO_PROXY_MAX_BYTES=50000000
AUTH_HELPER_VIDEO_PROXY_TIMEOUT_SECONDS=20
AUTH_HELPER_VIDEO_PROXY_UPSTREAM_CHUNK_BYTES=262144
AUTH_HELPER_VIDEO_PROXY_UPSTREAM_CHUNK_TIMEOUT_SECONDS=6
